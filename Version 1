                        </thead>
                            <tbody>
                        <tr>
                            <td>CHICKEN</td>
                            <td>11.95€</td>
                        </tr>
                        <tr>
                            <td>BEEF</td>
                            <td>12.95€</td>
                        </tr>
                        <tr>
                            <td>SHRIMP</td>
                            <td>13.95€</td>
                        </tr>
                            </tbody>
                    </table>
                </div>
            </div>
