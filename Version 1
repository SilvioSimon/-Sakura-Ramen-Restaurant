        </div>
    </section>

    <footer>

        <div class="footer-con">
            <div class="footer-logo">
                <img src="./img/5_section_footer/PNG/sakura_ramen_logo_and_text.png" alt="logo with text SAKURA RAMEN">
            </div>

            <div class="social_media-logos">
                <a href="https://www.tripadvisor.de/" target="_blank"><img
                        src="./img/5_section_footer/PNG/tripadvisor_logo.png" alt="Tripadvisor link"></a>
                <a href="https://www.facebook.com/" target="_blank"><img
                        src="./img/5_section_footer/PNG/facebook_logo.png" alt="Facebook link"></a>
