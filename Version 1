         /*Pick_n_add_text*/
        h3 {
            font-family: "Economica", sans-serif;
            font-weight: bold;
            font-size: 56px;
        }

        body p, a {
            font-family: "Raleway", sans-serif;
            font-weight: 400;
            font-size: 24px;
            font-style: normal;
            font-optical-sizing: auto;
            color: #000000;
        }
        /*link_white*/
        a {
            color: #ffffff;
            text-decoration: none;
        }      
        
        .navlink {
            color: #ffffff;
            transform: scale(1.0);
            font-weight: 400;
            transition-duration: 0.15s;
        }

        .navlink:hover {
            color: #ffffff;
            font-weight: 800;
            transition-duration: 0.1s;
        }

        /*our_menu_price*/
        table, td {
