        .phone-icon {
            height: 24px;
            width: 24px;
        }

        nav {
            display: flex;
            flex-direction: row;
            width: 44vw;
            justify-content: space-between;
            align-items: center;
        }

        .phone-button {
            border: solid white 2px;
            background-color: #9F0908;
            padding: 8px;
            border-radius: 12px;
            width: 200px;
            display: flex;
            justify-content: space-around;
            align-items: center;
        }

        .phone-button:hover {
            background-color: #c41212;
            transform: scale(1.02);
            transition-duration: 0.2s;
        }
        /*Order*/
        .order-section {
            margin: 120px 160px;
        }

        .order-section-object {
            display: flex;
            flex-direction: row;
            justify-content: center;
            align-items: center;
            margin: 0 0 64px;
        }

        .order-section img {
            width: 128px;
        }

        .pick-container {
            width: 200px;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            text-align: center;
        }

        .pick-container-object {
            margin: 0;
        }

        img.pick-container-object {
            margin: 0 0 16px;
        }

        .pick-con {
            display: flex;
            justify-content: space-around;
        }
        /*menu*/
        .menu-con {
            padding: 120px 0;
            margin: 0 160px;
        }

        .menu-section {
            background-image: url(./img/3_section_our_menu/JPG/section_our_menu_bg.jpg);
        }

