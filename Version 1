<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🍜 Sakura Ramen</title>



    <style>
        html {
            scroll-behavior: smooth;
            display: block;
        }

        body {
            background-color: #ffffff;
            margin: 0;
        }

        /*sakure_ramen_title*/
        h1 {
            font-family: "Raleway", sans-serif;
            font-size: 96px;
            font-weight: bold;
            font-optical-sizing: auto;
        }
        /*subtitle*/
