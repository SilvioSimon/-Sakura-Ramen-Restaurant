            display: flex;
            flex-direction: row;
            justify-content: center;
            align-items: center;
            margin: 0 0 64px;
        }

        .menu-section img {
            width: 352px;
            height: 352px;
        }

        .menu-container-tonkatsu {
            display: flex;
            justify-content: flex-start;
            align-items: center;
            margin: 0 0 56px;
        }

        .menu-container-spicy_miso {
            display: flex;
            flex-direction: row-reverse;
            justify-content: flex-start;
            align-items: center;
            margin: 0 0 56px;
        }

        .menu-container-shio {
            display: flex;
            justify-content: flex-start;
            align-items: center;
        }

        .menu-text {
            margin-left: 80px;
        }

        .menu-text-reverse {
            height: fit-content;
            margin-right: 80px;
        }

        .menu-text tbody {
            display: flex;
            flex-direction: column;
            margin: 16px 0 0;
        }

        .menu-text tr {
            margin: 0 0 8px;
        }

        .menu-text-reverse tbody {
            display: flex;
            flex-direction: column;
            justify-content: center;
            margin: 16px 0 0;

        }

        .menu-text-reverse thead {
            margin: 0 0 16px;
        }

        .menu-text-reverse tr {
            margin: 0 0 8px;
        }
        /*location*/
        .location-section-container {
            margin: 120px 0 0;
        }

        h2.location-section-object {
            display: flex;
            flex-direction: row;
            justify-content: center;
            align-items: center;
            margin: 0 0 8px;
        }

        .location-container {
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0 0 64px;
        }

        .location-container-object {
            margin: 0;
        }

        p.location-container-object {
            width: 410px;
        }

        img.location-container-object {
            height: 24px;
        }
        /*footer*/
        .footer-logo img {
            height: 44px;
        }

        .social_media-logos {
            width: 160px;
            height: 44px;
            display: flex;
            justify-content: space-around;
        }

        .social_media-logos img {
            width: 40px;
            height: 40px;
        }


        .footer-con {
            margin: 0 160px;
            height: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }



